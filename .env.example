# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Solana Configuration
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Admin & Treasury Wallets
NEXT_PUBLIC_ADMIN_WALLET=YOUR_ADMIN_WALLET_ADDRESS
NEXT_PUBLIC_TREASURY_WALLET=YOUR_TREASURY_WALLET_ADDRESS

# App Config
NEXT_PUBLIC_APP_NAME=EngageX
NEXT_PUBLIC_APP_URL=http://localhost:3000
